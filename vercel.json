{
    "buildCommand": "cd client && npm install && npm run build",
    "outputDirectory": "client/build",
    "framework": "create-react-app",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/pyq/:uuid",
            "destination": "/api/question"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}