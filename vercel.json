{
    "buildCommand": "cd client && npm install && npm run build",
    "outputDirectory": "client/build",
    "framework": "create-react-app",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/api/sitemap",
            "destination": "/api/sitemap"
        },
        {
            "source": "/pyq/:uuid",
            "destination": "/api/question"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/api/sitemap",
            "headers": [
                { "key": "Content-Type", "value": "application/xml" },
                { "key": "Cache-Control", "value": "s-maxage=3600, stale-while-revalidate" }
            ]
        },
        {
            "source": "/robots.txt",
            "headers": [
                { "key": "Cache-Control", "value": "s-maxage=86400" }
            ]
        },
        {
            "source": "/sitemap.xml",
            "headers": [
                { "key": "Content-Type", "value": "application/xml" },
                { "key": "Cache-Control", "value": "s-maxage=3600" }
            ]
        }
    ]
}
